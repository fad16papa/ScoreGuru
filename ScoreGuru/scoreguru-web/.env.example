# ScoreGuru web — copy to `.env` locally (never commit real secrets)

VITE_CLERK_PUBLISHABLE_KEY=
VITE_SCOREGURU_API_BASE_URL=http://localhost:5000/api
VITE_CLERK_JWT_TEMPLATE=

# Live score auto-polling (off by default — protects API-SPORTS quota)
VITE_SCOREGURU_ENABLE_LIVE_POLLING=false
VITE_SCOREGURU_LIVE_POLLING_SECONDS=60
